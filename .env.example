# ============================================
# AgentFabric 环境变量配置示例
# 复制此文件为 .env 并修改配置
# ============================================

# --------------------------------------------
# 服务器配置
# --------------------------------------------
# 服务端口
SERVER_PORT=3000

# 服务主机
SERVER_HOST=127.0.0.1

# 运行环境: development | production | test
NODE_ENV=development

# --------------------------------------------
# 数据库配置 (PostgreSQL)
# --------------------------------------------
# 数据库连接URL
DATABASE_URL=postgresql://user:password@localhost:5432/agentfabric

# 是否启用数据库查询日志
DATABASE_LOGGING=false

# 数据库连接池大小
DATABASE_POOL_SIZE=10

# --------------------------------------------
# Redis 配置
# --------------------------------------------
# Redis 主机
REDIS_HOST=localhost

# Redis 端口
REDIS_PORT=6379

# Redis 密码（可选）
# REDIS_PASSWORD=

# Redis 数据库索引 (0-15)
REDIS_DB=0

# 是否启用 TLS
REDIS_TLS=false

# --------------------------------------------
# 日志配置
# --------------------------------------------
# 日志级别: trace | debug | info | warn | error | fatal
LOG_LEVEL=debug

# 是否输出到文件
LOG_FILE=false

# 日志文件路径
LOG_FILE_PATH=./logs/app.log

# 是否启用彩色输出（开发环境）
LOG_COLORIZE=true

# --------------------------------------------
# 安全配置
# --------------------------------------------
# JWT 密钥（生产环境必须更换为强密钥）
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# JWT 过期时间（秒）
JWT_EXPIRES_IN=7200

# 密码加盐轮数
BCRYPT_ROUNDS=10

# CORS 允许的源
CORS_ORIGIN=*

# 是否启用 Helmet 安全头
SECURITY_HELMET=true

# --------------------------------------------
# 限流配置
# --------------------------------------------
# 默认最大请求数（每分钟）
RATE_LIMIT_MAX=100

# 限流时间窗口
RATE_LIMIT_WINDOW=1 minute
