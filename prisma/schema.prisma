generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  // 数据库名: agentfabric (由 .env 中的 DATABASE_URL 指定)
}

// 命名空间：隔离不同租户/用户的数据
model Namespace {
  id        String   @id @default(uuid())
  name      String   @unique
  apiKeys   ApiKey[]
  agents    Agent[]
  requests  Request[]
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("namespaces")
}

// Agent：AI 智能体定义
model Agent {
  id          String    @id @default(uuid())
  namespaceId String    @map("namespace_id")
  name        String
  description String?
  config      Json      // Agent 配置（模型、系统提示等）
  tools       Json      // 可用工具列表
  isActive    Boolean   @default(true) @map("is_active")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  requests    Request[]

  namespace Namespace @relation(fields: [namespaceId], references: [id], onDelete: Cascade)

  @@index([namespaceId])
  @@map("agents")
}

// Request：API 请求记录
model Request {
  id          String   @id @default(uuid())
  namespaceId String   @map("namespace_id")
  agentId     String   @map("agent_id")
  method      String   // HTTP 方法
  path        String   // 请求路径
  headers     Json?    // 请求头
  body        Json?    // 请求体
  response    Json?    // 响应数据
  statusCode  Int?     @map("status_code")
  durationMs  Int?     @map("duration_ms") // 请求耗时
  error       String?  // 错误信息
  createdAt   DateTime @default(now()) @map("created_at")

  namespace Namespace @relation(fields: [namespaceId], references: [id], onDelete: Cascade)
  agent     Agent     @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@index([namespaceId])
  @@index([agentId])
  @@index([createdAt])
  @@map("requests")
}

// ApiKey：API 密钥管理
model ApiKey {
  id          String    @id @default(uuid())
  namespaceId String    @map("namespace_id")
  keyHash     String    @unique @map("key_hash") // 密钥哈希值
  name        String?   // 密钥名称（用于识别）
  scopes      String[]  // 权限范围
  isActive    Boolean   @default(true) @map("is_active")
  lastUsedAt  DateTime? @map("last_used_at")
  expiresAt   DateTime? @map("expires_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  namespace Namespace @relation(fields: [namespaceId], references: [id], onDelete: Cascade)

  @@index([namespaceId])
  @@index([keyHash])
  @@map("api_keys")
}

// RateLimitConfig：namespace 级别限流配置
model RateLimitConfig {
  id                String   @id @default(uuid())
  namespace         String   @unique // namespace 名称
  maxRequests       Int      @default(100) @map("max_requests") // 最大请求数
  timeWindowSeconds Int      @default(60) @map("time_window_seconds") // 时间窗口（秒）
  enabled           Boolean  @default(true) // 是否启用限流
  description       String?  // 配置描述
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  @@index([namespace])
  @@map("rate_limit_configs")
}
